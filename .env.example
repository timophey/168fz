# Конфигурация микросервиса 168-ФЗ Text Checker

# Порт для запуска сервера
PORT=8000

# Хост для привязки
HOST=0.0.0.0

# Путь к словарям (относительно /app в контейнере)
DICTIONARIES_DIR=/app/dictionaries/data

# Админ-ключ для доступа к админ-панели (обязателен для синхронизации и управления словарями)
# Рекомендуется использовать сложный пароль
ADMIN_KEY=admin123

# Режим отладки (true/false)
DEBUG=false
